@page
@model WebProjectServ.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card modern-card">
                <div class="card-header modern-card-header">
                    <h4 class="mb-0">Create your profile</h4>
                </div>

                <div class="card-body">
                    <form method="post">

                        <div class="mb-3">
                            <label asp-for="Input.LastName" class="form-label">Last Name</label>
                            <input asp-for="Input.LastName" class="form-control modern-input" placeholder="Enter last name" />
                            <span asp-validation-for="Input.LastName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.FirstName" class="form-label">First Name</label>
                            <input asp-for="Input.FirstName" class="form-control modern-input" placeholder="Enter first name" />
                            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control modern-input" type="email" placeholder="example@gmail.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Phone" class="form-label">Phone number</label>
                            <input asp-for="Input.Phone" class="form-control modern-input" placeholder="+380..." />
                            <span asp-validation-for="Input.Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="Input.DateOfBirth" class="form-control modern-input" type="date" />
                            <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                        </div>

                        <hr />
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Create your Password</label>
                            <input asp-for="Input.Password" class="form-control modern-input" type="password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control modern-input" type="password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                                ← Back to Main Page
                            </a>
                            <button type="submit" class="btn btn-primary modern-btn">
                                Register
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

</div>