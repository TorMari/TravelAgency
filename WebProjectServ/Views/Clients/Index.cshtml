@model IEnumerable<WebProjectServ.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Clients</h2>
        @* <a asp-action="Create" class="btn btn-primary modern-btn">
            + Add New Client
        </a> *@
    </div>

    <div class="card modern-card">
        <div class="card-body">

            <table class="table table-hover modern-table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Last Name</th>
                        <th>First Name</th>
                        <th>Email</th>
                        <th>Phone number</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge modern-badge">@item.Id</span></td>
                            <td>@item.LastName</td>
                            <td>@item.FirstName</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td class="text-center">

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info modern-details-btn">
                                    Details
                                </a>

                                @* <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning modern-edit-btn">
                                    Edit
                                </a> 

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger modern-delete-btn">
                                    Delete
                                </a> *@

                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    No clients found.
                </div>
            }

        </div>
    </div>

</div>
