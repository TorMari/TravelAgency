@model WebProjectServ.Models.Client

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">

    <div class="card modern-card">

        <div class="card-header modern-card-header">
            <h4 class="mb-0">
                Adding new information 
            </h4>
        </div>

        <div class="card-body">

            <div class="alert modern-confirming">
                Are you sure you want to save this client?
            </div>

            <dl class="row">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">
                    <strong>@Model.FirstName @Model.LastName</strong>
                </dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone number</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">
                    @Model.DateOfBirth.ToShortDateString()
                </dd>

            </dl>

        </div>

        <div class="card-footer modern-footer-actions">
            @if (User.Identity.IsAuthenticated && User.IsInRole("admin"))
            {
                <a asp-action="CancelCreate" class="btn btn-outline-secondary modern-action-btn">
                    Cancel
                </a>
                <form asp-action="Confirm" class="d-inline" method="post">
                    <input type="hidden" name="mode" value="@ViewBag.Mode" />
                    <button type="submit" class="btn btn-success modern-save-btn">Confirm</button>
                </form>
            }
            else
            {
                <a asp-controller="Clients" asp-action="Details" asp-route-id="@User.FindFirst("ClientId")?.Value" class="btn btn-outline-secondary modern-action-btn">
                    Cancel
                </a>
                <form asp-action="Confirm" class="d-inline" method="post">
                    <input type="hidden" name="mode" value="@ViewBag.Mode" />
                    <button type="submit" class="btn btn-success modern-save-btn">Confirm</button>
                </form>
            }
            
        </div>

    </div>

</div>


