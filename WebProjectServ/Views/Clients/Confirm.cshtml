@model WebProjectServ.Models.Client

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">

    <div class="card shadow border-warning">

        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0">
                Adding new information 
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Are you sure you want to save this client?
            </div>

            <dl class="row">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">
                    <strong>@Model.FirstName @Model.LastName</strong>
                </dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone number</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">
                    @Model.DateOfBirth.ToShortDateString()
                </dd>

            </dl>

        </div>

        <div class="card-footer text-end">
            <a asp-action="CancelCreate" class="btn btn-secondary">
                Cancel
            </a>
            <form asp-action="Confirm" class="d-inline" method="post">
                <input type="hidden" name="mode" value="@ViewBag.Mode" />
                <button type="submit" class="btn btn-success">Confirm</button>
            </form>

        </div>

    </div>

</div>


