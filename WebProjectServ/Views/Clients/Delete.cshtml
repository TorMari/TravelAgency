@model WebProjectServ.Models.Client

@{
    ViewData["Title"] = "Clients";
}


<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0">
                Delete Client №@Model.Id
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Are you sure you want to delete this client and all associated bookings?
                This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">
                    <strong>@Model.FirstName @Model.LastName</strong>
                </dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone number</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">
                    @Model.DateOfBirth.ToShortDateString()
                </dd>

                <dt class="col-sm-3">Number of Bookings</dt>
                <dd class="col-sm-9">
                    @Model.Bookings.Count
                </dd>
            </dl>

        </div>

        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>
            <form asp-action="Delete" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </form>

        </div>

    </div>

</div>
