@model WebProjectServ.Models.Client

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">

    <div class="card modern-card">
        <div class="card-header modern-card-header">
            <h4 class="mb-0">
                Client №@Model.Id — @Model.FirstName @Model.LastName
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone number:</strong> @Model.Phone</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToShortDateString()</p>
                </div>
            </div>

            <hr />

            
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-3">Bookings</h5>
                <a asp-controller="Bookings"
                   asp-action="Create"
                   asp-route-clientId="@Model.Id"
                   class="btn btn-primary modern-action-btn">
                    + Add New Booking
                </a>
            </div>

            @if (Model.Bookings != null && Model.Bookings.Any())
            {
                <table class="table table-hover modern-table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tour Id</th>
                            <th>Name</th>
                            <th>Country</th>
                            <th>Total Price, €</th>
                            <th>Status</th>
                            @if (User.Identity.IsAuthenticated && !User.IsInRole("admin"))
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bookings)
                        {
                            <tr>
                                <td>@b.Tour.Id</td>
                                <td>@b.Tour.Name</td>
                                <td>@b.Tour.Country</td>
                                <td>@(b.NumberOfPeople * b.Tour.Price)</td>
                                <td>
                                    @{
                                        var statusClass = @b.Status switch
                                        {
                                            "Confirmed" => "status-confirmed",
                                            "Pending" => "status-pending",
                                            "Cancelled" => "status-cancelled",
                                            _ => "status-default"
                                        };
                                    }
                                    <span class="badge @statusClass">
                                        @b.Status
                                    </span>
                                </td>
                                @if (!User.IsInRole("admin"))
                                {
                                    <td class="text-center">
                                        <a asp-controller="Bookings" asp-action="Details" asp-route-id="@b.Id"
                                           class="btn btn-sm btn-info modern-details-btn">
                                            Details
                                        </a>
                                        <a asp-controller="Bookings" asp-action="Edit" asp-route-id="@b.Id"
                                           class="btn btn-sm btn-danger modern-delete-btn">
                                            Cancel the booking
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">No bookings yet.</div>
            }

        </div>

        <div class="card-footer modern-footer-actions">
            @if (!User.IsInRole("admin"))
            {
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                    ← Back to Main Page
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning modern-edit-btn">
                    Edit Profile
                </a>
                <a asp-page="/Account/DeleteAccount" asp-area="Identity" class="btn btn-danger modern-delete-btn">
                    Delete Account
                </a>

            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                    ← Back to list
                </a>

            }
            
        </div>
    </div>

</div>
