@model WebProjectServ.Models.Client

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0">
                Client №@Model.Id — @Model.FirstName @Model.LastName
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone number:</strong> @Model.Phone</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToShortDateString()</p>
                </div>
            </div>

            <hr />

            <h5 class="mb-3">Bookings</h5>

            @if (Model.Bookings != null && Model.Bookings.Any())
            {
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Tour Id</th>
                            <th>Name</th>
                            <th>Country</th>
                            <th>Total Price, €</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bookings)
                        {
                            <tr>
                                <td>@b.Tour.Id</td>
                                <td>@b.Tour.Name</td>
                                <td>@b.Tour.Country</td>
                                <td>@(b.NumberOfPeople * b.Tour.Price)</td>
                                <td>
                                    @{
                                        var statusClass = @b.Status switch
                                        {
                                            "Confirmed" => "bg-success",
                                            "Pending" => "bg-warning text-dark",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">
                                        @b.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-muted">No bookings yet.</div>
            }

        </div>

        <div class="card-footer text-end">

            <a asp-action="Index" class="btn btn-secondary">
                ← Back to list
            </a>

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit
            </a>

            <a asp-controller="Bookings"
               asp-action="Create"
               asp-route-clientId="@Model.Id"
               class="btn btn-success">
                + Add New Booking
            </a>

        </div>
    </div>

</div>
