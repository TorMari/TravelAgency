@model IEnumerable<WebProjectServ.Models.Tour>

@{
    ViewData["Title"] = "Tours";
}


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Tours</h2>
        
        @if (User.Identity.IsAuthenticated && User.IsInRole("admin"))
        {
            <a asp-action="Create" class="btn btn-primary modern-btn">
                + Add New Tour
            </a>
        }
    </div>
    <div class="card modern-card">
        <div class="card-body">
            <table class="table table-hover modern-table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Country</th>
                        <th>Start Date</th>
                        <th>Price, €</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge modern-badge">@item.Id</span></td>
                            <td>@item.Name</td>
                            <td>@item.Country</td>
                            <td>@item.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.Price</td>
                            <td class="text-center">

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info modern-details-btn">
                                    Details
                                </a>
                                @if (User.Identity.IsAuthenticated && User.IsInRole("admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning modern-edit-btn">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger modern-delete-btn">
                                        Delete
                                    </a>
                                }
                                
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    No tours found.
                </div>
            }
        </div>
    </div>
</div>
