@model WebProjectServ.Models.Tour

@{
    ViewData["Title"] = "Tours";
}

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0">
                Tour №@Model.Id — @Model.Name
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <p><strong>Country:</strong> @Model.Country</p>
                    <p><strong>Description:</strong> @Model.Description</p>
                    <p><strong>Duration Days:</strong> @Model.DurationDays</p>
                    <p><strong>Start Date:</strong> @Model.StartDate</p>
                    <p><strong>Price, €:</strong> @Model.Price</p>
                </div>
            </div>

            <hr />

            <h5 class="mb-3">Bookings</h5>

            @if (Model.Bookings != null && Model.Bookings.Any())
            {
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Client Id</th>
                            <th>Full Name</th>
                            <th>Booking Date</th>
                            <th>Number of People</th>
                            <th>Total Price, €</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bookings)
                        {
                            <tr>
                                <td>@b.Client.Id</td>
                                <td>@b.Client.FullName</td>
                                <td>@b.BookingDate</td>
                                <td>@b.NumberOfPeople</td>
                                <td>@(b.NumberOfPeople * b.Tour.Price)</td>
                                <td>
                                    @{
                                        var statusClass = @b.Status switch
                                        {
                                            "Confirmed" => "bg-success",
                                            "Pending" => "bg-warning text-dark",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">
                                        @b.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-muted">No bookings yet.</div>
            }

        </div>

        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">
                ← Back to list
            </a>
            
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit
            </a>

            <a asp-controller="Bookings"
               asp-action="Create"
               asp-route-tourId="@Model.Id"
               class="btn btn-success">
                + Add New Booking
            </a>
        </div>
    </div>

</div>