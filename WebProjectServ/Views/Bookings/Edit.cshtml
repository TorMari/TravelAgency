@model WebProjectServ.Models.Booking

@{
    ViewData["Title"] = "Bookings";
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card modern-card">
                <div class="card-header modern-card-header">
                    <h4 class="mb-0">Edit Booking Information</h4>
                </div>
                
                <div class="card-body">
                    <form asp-action="Edit">
                        <input asp-for="Id" type="hidden" asp-for="Id" />

                        @if (User.Identity.IsAuthenticated && !User.IsInRole("admin"))
                        {
                            <div class="mb-3">
                                <label asp-for="ClientId"></label>
                                <select asp-for="ClientId" disabled class="form-control modern-selection" asp-items="ViewBag.ClientId"></select>
                                <input type="hidden" asp-for="ClientId" />
                            </div>


                            <div class="mb-3">
                                <label asp-for="TourId"></label>
                                <select asp-for="TourId" disabled class="form-control modern-selection" asp-items="ViewBag.TourId"></select>
                                <input type="hidden" asp-for="TourId" />
                            </div> 

                            <div class="mb-3">
                                <label asp-for="NumberOfPeople"></label>
                                <input asp-for="NumberOfPeople" readonly class="form-control modern-input" />
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="ClientId"></label>
                                <select asp-for="ClientId" class="form-control modern-selection" asp-items="ViewBag.ClientId"></select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="TourId"></label>
                                <select asp-for="TourId" class="form-control modern-selection" asp-items="ViewBag.TourId"></select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NumberOfPeople"></label>
                                <input asp-for="NumberOfPeople" class="form-control modern-input" />
                            </div>
                        } 

                        <div class="mb-4">
                            <label asp-for="Status"></label>
                            <select asp-for="Status" class="form-control modern-selection">
                                <option value="" disabled selected>Choose status option</option>
                                @if (User.Identity.IsAuthenticated && User.IsInRole("admin"))
                                {
                                    <option value="Pending">Pending</option>
                                    <option value="Confirmed">Confirmed</option>
                                }
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between">
                            @if (User.Identity.IsAuthenticated && User.IsInRole("admin"))
                            {
                                <div>
                                    <a asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                                        ← Back to list
                                    </a>
                                </div>

                                <div>
                                    <button type="submit" class="btn btn-primary modern-btn">
                                        Save Booking
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div>
                                    <a asp-controller="Clients" asp-action="Details" asp-route-id="@User.FindFirst("ClientId")?.Value" class="btn btn-outline-secondary modern-action-btn">
                                        ← Back to Profile
                                    </a>
                                </div>

                                <div>
                                    <button type="submit" class="btn btn-danger modern-delete-btn">
                                        Cancel Booking
                                    </button>
                                </div>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
