@model WebProjectServ.Models.Booking

@{
    ViewData["Title"] = "Bookings";
}


<div class="container mt-4">

    <div class="card modern-card">

        <div class="card-header modern-card-header">
            <h4 class="mb-0">
                Adding new information
            </h4>
        </div>

        <div class="card-body">

            @if (User.IsInRole("admin") || ViewBag.Mode == "Create")
            {
                <div class="modern-confirming">
                    Are you sure you want to save this booking?
                </div>
            }
            else
            {
                <div class="modern-danger">
                    Are you sure you want to <strong>cancel</strong> this booking? This action cannot be undone!
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Client Id</dt>
                <dd class="col-sm-9">@Model.ClientId</dd>

                <dt class="col-sm-3">Tour Id</dt>
                <dd class="col-sm-9">@Model.TourId</dd>

                <dt class="col-sm-3">Number of People</dt>
                <dd class="col-sm-9">@Model.NumberOfPeople</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @{
                        var statusClass = Model.Status switch
                        {
                            "Confirmed" => "status-confirmed",
                            "Pending" => "status-pending",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };
                    }
                    <span class="badge @statusClass">
                        @Model.Status
                    </span>
                </dd>
            </dl> 

        </div>

        <div class="card-footer modern-footer-actions">
            
            @if (User.IsInRole("admin") || ViewBag.Mode == "Create")
            {
                @if (ViewBag.FromClient != null)
                {
                    <a asp-controller="Clients"
                       asp-action="Details"
                       asp-route-id="@ViewBag.FromClient"
                       class="btn btn-outline-secondary modern-action-btn">
                        Cancel
                    </a>
                }
                else if (ViewBag.FromTour != null)
                {
                    <a asp-controller="Tours"
                       asp-action="Details"
                       asp-route-id="@ViewBag.FromTour"
                       class="btn btn-outline-secondary modern-action-btn">
                        Cancel
                    </a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                        Cancel
                    </a>
                }
                <form asp-action="Confirm" class="d-inline" method="post">
                    <input type="hidden" name="mode" value="@ViewBag.Mode" />
                    <button type="submit" class="btn btn-success modern-save-btn">Confirm</button>
                </form>
            }
            else
            {
                <a asp-controller="Clients" asp-action="Details" asp-route-id="@User.FindFirst("ClientId")?.Value" class="btn btn-outline-secondary modern-action-btn">
                    Cancel
                </a>

                <form asp-action="Confirm" class="d-inline" method="post">
                    <input type="hidden" name="mode" value="@ViewBag.Mode" />
                    <button type="submit" class="btn btn-danger modern-delete-btn">Confirm</button>
                </form>
            }

        </div>

    </div>

</div>


