@model WebProjectServ.Models.Booking

@{
    ViewData["Title"] = "Bookings";
}

<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0">
                Delete Booking №@Model.Id
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Are you sure you want to delete this booking?
                This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Model.Client.FullName</dd>

                <dt class="col-sm-3">Tour</dt>
                <dd class="col-sm-9">@Model.Tour.Name</dd>

                <dt class="col-sm-3">Booking Date</dt>
                <dd class="col-sm-9">@Model.BookingDate</dd>

                <dt class="col-sm-3">Number of People</dt>
                <dd class="col-sm-9">@Model.NumberOfPeople</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @{
                        var statusClass = @Model.Status switch
                        {
                            "Confirmed" => "bg-success",
                            "Pending" => "bg-warning text-dark",
                            "Cancelled" => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @statusClass">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">Total Price, €</dt>
                <dd class="col-sm-9">@Model.TotalPrice</dd>
            </dl>

        </div>

        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

            <form asp-action="Delete" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </form>

        </div>

    </div>

</div>
