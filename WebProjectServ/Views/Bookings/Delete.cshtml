@model WebProjectServ.Models.Booking

@{
    ViewData["Title"] = "Bookings";
}

<div class="container mt-4">

    <div class="card modern-card">

        <div class="card-header modern-card-header">
            <h4 class="mb-0">
                Delete Booking №@Model.Id
            </h4>
        </div>

        <div class="card-body">

            <div class="modern-danger">
                Are you sure you want to delete this booking?
                This action cannot be undone.
            </div>

            <dl class="row">

                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Model.Client.FullName</dd>

                <dt class="col-sm-3">Tour</dt>
                <dd class="col-sm-9">@Model.Tour.Name</dd>

                <dt class="col-sm-3">Booking Date</dt>
                <dd class="col-sm-9">@Model.BookingDate</dd>

                <dt class="col-sm-3">Number of People</dt>
                <dd class="col-sm-9">@Model.NumberOfPeople</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">

                    @{
                        var statusClass = Model.Status switch
                        {
                            "Confirmed" => "status-confirmed",
                            "Pending" => "status-pending",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };
                    }

                    <span class="status-badge @statusClass">
                        @Model.Status
                    </span>

                </dd>

                <dt class="col-sm-3">Total Price, €</dt>
                <dd class="col-sm-9">@Model.TotalPrice</dd>

            </dl>

        </div>

        <div class="card-footer modern-footer-actions">

            <a asp-action="Index" class="btn btn-outline-secondary modern-action-btn">
                Cancel
            </a>

            <form asp-action="Delete" class="d-inline">
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger modern-delete-btn">
                    Delete
                </button>
            </form>

        </div>

    </div>

</div>