@model WebProjectServ.Models.Booking

@{
    ViewData["Title"] = "Bookings";
}


<div asp-validation-summary="All" class="text-danger mb-3"></div>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">Create New Booking</h4>
                </div>
                
                <div class="card-body">
                    <form asp-action="Create">

                        <input type="hidden" name="fromClient" value="@ViewBag.FromClient" />
                        <input type="hidden" name="fromTour" value="@ViewBag.FromTour" />

                        @if (ViewBag.Order == "clientFirst")
                        {
                            <div class="mb-3">
                                <label class="form-label">Client</label>
                                <input class="form-control"
                                       value="@ViewBag.FromClient"
                                       disabled />
                                <input type="hidden" asp-for="ClientId" value="@ViewBag.FromClient" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Tour</label>
                                <select asp-for="TourId"
                                        class="form-select"
                                        asp-items="ViewBag.TourId">
                                </select>
                            </div>
                        }
                        else if (ViewBag.Order == "tourFirst")
                        {
                            <div class="mb-3">
                                <label class="form-label">Tour</label>
                                <input class="form-control"
                                       value="@ViewBag.FromTour"
                                       disabled />
                                <input type="hidden" asp-for="TourId" value="@ViewBag.FromTour" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Client</label>
                                <select asp-for="ClientId"
                                        class="form-select"
                                        asp-items="ViewBag.ClientId">
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Client</label>
                                <select asp-for="ClientId"
                                        class="form-select"
                                        asp-items="ViewBag.ClientId">
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Tour</label>
                                <select asp-for="TourId"
                                        class="form-select"
                                        asp-items="ViewBag.TourId">
                                </select>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="NumberOfPeople" class="form-label">Number of People</label>
                            <input asp-for="NumberOfPeople" class="form-control" placeholder="Enter number of people"/>
                            <span asp-validation-for="NumberOfPeople" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="" disabled selected>Choose status option</option>
                                <option value="Pending">Pending</option>
                                <option value="Confirmed">Confirmed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between">
                            <div>
                                @if (ViewBag.FromClient != null)
                                {
                                    <a asp-controller="Clients"
                                       asp-action="Details"
                                       asp-route-id="@ViewBag.FromClient"
                                       class="btn btn-secondary">
                                        ← Back to Client
                                    </a>
                                }
                                else if (ViewBag.FromTour != null)
                                {
                                    <a asp-controller="Tours"
                                       asp-action="Details"
                                       asp-route-id="@ViewBag.FromTour"
                                       class="btn btn-secondary">
                                        ← Back to Tour
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="Index" class="btn btn-secondary">
                                        ← Back to list
                                    </a>
                                }
                            </div>

                            <div>
                                <button type="submit" class="btn btn-success">
                                    Save Booking
                                </button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
